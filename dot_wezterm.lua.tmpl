-- ── Tab labels: " <idx>  <icon> <dir>  <badge|dots> " ─────────────────────────
-- Per-pane Claude state comes from the `cc_state` user var the wez-tab-status hook
-- sets (working/done/error, cleared on exit). We show a coloured dot per pane,
-- wash the tab background by the most urgent state (error > done > working), and
-- tint the label to match — active or inactive tab, so a background Claude run
-- is obvious at a glance. The process icon is best-effort from the foreground
-- process; Claude is detected via the user var because Windows/WSL often report a
-- wrapper process rather than `claude`. Nerd-font lookups are fallback-guarded
-- (unknown names resolve to nil) so a missing glyph can't break the bar.
local PROC_ICONS = {
  pwsh = wezterm.nerdfonts.md_powershell, powershell = wezterm.nerdfonts.md_powershell,
  zsh = wezterm.nerdfonts.md_console, bash = wezterm.nerdfonts.md_console,
  sh = wezterm.nerdfonts.md_console, wsl = wezterm.nerdfonts.md_console,
  nvim = wezterm.nerdfonts.custom_vim, vim = wezterm.nerdfonts.custom_vim,
  git = wezterm.nerdfonts.dev_git, node = wezterm.nerdfonts.md_nodejs,
  python = wezterm.nerdfonts.md_language_python, python3 = wezterm.nerdfonts.md_language_python,
}
local ICON_CLAUDE   = wezterm.nerdfonts.md_robot or '*'
local ICON_FALLBACK = wezterm.nerdfonts.md_console or '>'
local ICON_ZOOM     = wezterm.nerdfonts.md_fullscreen or 'Z'
local TAB = {  -- derived from the active palette
  text = P.text, dim = P.overlay0,
  working = P.peach, done = P.green, error = P.maroon,
}

local function dir_leaf(pane)
  local cwd = pane.current_working_dir
  if not cwd then return nil end
  local p = (type(cwd) == 'userdata' and cwd.file_path) or tostring(cwd)
  p = p:gsub('^file://[^/]*', ''):gsub('[/\\]+$', '')
  return p:match('[^/\\]+$')
end

local function proc_leaf(pane)
  local name = pane.foreground_process_name
  if not name or name == '' then return nil end
  return (name:gsub('[/\\]+$', ''):match('[^/\\]+$') or name):gsub('%.exe$', ''):lower()
end

-- Claude state from a pane's user var: 'working'|'done'|'error' or nil.
local function pane_cc(pane)
  local s = pane.user_vars and pane.user_vars.cc_state
  if s == nil or s == '' then return nil end
  return s
end

wezterm.on('format-tab-title', function(tab, tabs, panes, cfg, hover, max_width)
  local active = tab.active_pane
  local leaf = wezterm.truncate_right(dir_leaf(active) or active.title or '', 24)

  -- icon: Claude (by user var) else the foreground process, with a fallback glyph.
  local icon
  if pane_cc(active) then
    icon = ICON_CLAUDE
  else
    local p = proc_leaf(active)
    icon = (p and PROC_ICONS[p]) or ICON_FALLBACK
  end

  -- per-pane dots + aggregate state; note Claude panes and zoom.
  local dots, agg, any_cc, zoomed = {}, nil, false, false
  for _, p in ipairs(tab.panes) do
    local s = pane_cc(p)
    if s then
      any_cc = true
      table.insert(dots, { c = TAB[s] or TAB.dim, g = '●' })
      if s == 'error' then agg = 'error'
      elseif s == 'done' and agg ~= 'error' then agg = 'done'
      elseif s == 'working' and not agg then agg = 'working' end
    else
      table.insert(dots, { c = TAB.dim, g = '○' })
    end
    if p.is_zoomed then zoomed = true end
  end

  -- label colour: cc state tints the tab even when it is not focused.
  local fg = TAB.text
  if agg == 'error' then fg = TAB.error
  elseif agg == 'done' then fg = TAB.done
  elseif agg == 'working' then fg = TAB.working
  elseif not tab.is_active then fg = TAB.dim end
  local bold = tab.is_active or agg ~= nil

  local items = {}
  if agg then
    table.insert(items, { Background = { Color = P['cc_' .. agg] } })
  end
  table.insert(items, { Attribute = { Intensity = bold and 'Bold' or 'Half' } })
  table.insert(items, { Foreground = { Color = fg } })
  table.insert(items, { Text = ' ' .. (tab.tab_index + 1) .. '  ' .. icon .. ' ' .. leaf .. ' ' })
  if any_cc then                         -- dots imply the pane count
    table.insert(items, { Text = ' ' })
    for _, d in ipairs(dots) do
      table.insert(items, { Foreground = { Color = d.c } })
      table.insert(items, { Text = d.g })
    end
  elseif #tab.panes > 1 then
    table.insert(items, { Foreground = { Color = TAB.dim } })
    table.insert(items, { Text = ' ' .. #tab.panes })
  end
  if zoomed then
    table.insert(items, { Foreground = { Color = TAB.dim } })
    table.insert(items, { Text = ' ' .. ICON_ZOOM })
  end
  table.insert(items, { Text = ' ' })
  return items
end)

-- ── Per-pane background + Claude tint (ConPTY-proof) ────────────────────────
-- The hook also emits an OSC 11 background tint, but on Windows ConPTY eats OSC
-- 10/11/12 before they reach WezTerm (the cc_state user var survives because
-- ConPTY passes the unknown OSC 1337 through verbatim — that's why the tab dots
-- work but the pane never tinted). Re-drive from cc_state + focus here:
-- user-var-changed fires reliably, and pane:inject_output feeds the OSC 11 into
-- WezTerm's own emulator, bypassing ConPTY entirely. Local panes, every platform;
-- mux/SSH panes (no inject_output) fall back to the hook's raw OSC 11. macOS/Linux
-- have no ConPTY so the hook's OSC 11 already works — this re-sets the same colour.
local CC_BG = { working = P.cc_working, done = P.cc_done, error = P.cc_error }
local pane_bg_applied = {}

local function pane_cc_state(pane)
  local s = pane.user_vars and pane.user_vars.cc_state
  if s == nil or s == '' then return nil end
  return s
end

local function pane_bg_color(pane, is_active)
  local cc = pane_cc_state(pane)
  if cc and CC_BG[cc] then return CC_BG[cc] end
  return is_active and P.pane_active or P.pane_inactive
end

local function clear_pane_bg_cache()
  for k in pairs(pane_bg_applied) do pane_bg_applied[k] = nil end
end

local function inject_pane_surface(p, bg, fg)
  pcall(function()
    p:inject_output('\x1b]11;' .. bg .. '\x07')
    p:inject_output('\x1b]10;' .. fg .. '\x07')
  end)
end

local function sync_pane_backgrounds(window, force)
  local mux_win = window:mux_window()
  if not mux_win then return end
  for _, tab in ipairs(mux_win:tabs()) do
    local active = tab:active_pane()
    local active_id = active and active:pane_id()
    for _, p in ipairs(tab:panes()) do
      local pid = p:pane_id()
      local bg = pane_bg_color(p, pid == active_id)
      local key = bg .. '|' .. P.text
      if force or pane_bg_applied[pid] ~= key then
        pane_bg_applied[pid] = key
        inject_pane_surface(p, bg, P.text)
      end
    end
  end
end

wezterm.on('user-var-changed', function(window, pane, name, value)
  if name ~= 'cc_state' then return end
  sync_pane_backgrounds(window, true)
end)

wezterm.on('window-config-reloaded', function(window)
  clear_pane_bg_cache()
  sync_pane_backgrounds(window, true)
end)

-- ── Top-right status: [⬡ workspace │] user@host │ current path ─────────────────
-- Identity and path follow the *active pane* (OSC 7, shell-integration user vars,
-- SSH/WSL domain, then pane title), not the WezTerm GUI process.
local function titlecase(s)
  if not s or s == '' then return '' end
  return s:sub(1, 1):upper() .. s:sub(2):lower()
end

local function hostname_short(h)
  if not h or h == '' or h == 'localhost' then return '' end
  local dot = h:find('[.]')
  if dot then h = h:sub(1, dot - 1) end
  return h
end

local function identity_from_title(title)
  if not title or title == '' then return nil, nil end
  local user, host = title:match('^([%w%-_]+)@([%w%-_]+)')
  if user and host then return user, host end
  host = title:match('^([^:%s]+):')
  if host and host ~= '' and not host:find('[%./\\]') then return nil, host end
  return nil, nil
end

local function path_from_title(title)
  if not title or title == '' then return '' end
  local path = title:match(':[%s]*(.*)$')
  if not path then return '' end
  path = path:gsub('^%s+', ''):gsub('%s+$', '')
  return path
end

local function pane_title(pane)
  local title = pane.title
  if (not title or title == '') and pane.get_title then title = pane:get_title() end
  return title or ''
end

local function identity_from_domain(domain)
  if not domain or domain == '' then return nil, nil end
  local label = domain:match('^SSH:(.+)$') or domain:match('^WSL:(.+)$')
  if not label then return nil, nil end
  local user, host = label:match('^([^@]+)@([^:]+)')
  if user and host then return user, host end
  return nil, label:gsub(':%d+$', '')
end

local function pane_location(pane)
  local user, host, path = '', '', ''

  local uv = pane.user_vars
  if uv then
    if uv.WEZTERM_USER and uv.WEZTERM_USER ~= '' then user = uv.WEZTERM_USER end
    if uv.WEZTERM_HOST and uv.WEZTERM_HOST ~= '' then host = uv.WEZTERM_HOST end
  end

  local cwd_uri = pane:get_current_working_dir()
  if not cwd_uri and pane.current_working_dir then cwd_uri = pane.current_working_dir end
  if cwd_uri then
    if type(cwd_uri) == 'userdata' then
      path = cwd_uri.file_path or ''
      if cwd_uri.username and cwd_uri.username ~= '' then user = cwd_uri.username end
      local h = hostname_short(cwd_uri.host)
      if h ~= '' then host = h end
    else
      local s = tostring(cwd_uri)
      if s:sub(1, 7) == 'file://' then
        s = s:sub(8)
        local slash = s:find('/')
        if slash then
          host = hostname_short(s:sub(1, slash - 1))
          path = s:sub(slash):gsub('%%(%x%x)', function(hex)
            return string.char(tonumber(hex, 16))
          end)
        end
      else
        path = s
      end
    end
  end

  if host == '' or user == '' then
    local du, dh = identity_from_domain(pane:get_domain_name())
    if dh and host == '' then host = dh end
    if du and user == '' then user = du end
  end

  if host == '' or user == '' then
    local title = pane_title(pane)
    local tu, th = identity_from_title(title)
    if th and host == '' then host = th end
    if tu and user == '' then user = tu end
  end

  if path == '' then
    path = path_from_title(pane_title(pane))
  end

  if host == '' then host = hostname_short(wezterm.hostname() or '') end
  if user == '' then user = os.getenv('USERNAME') or os.getenv('USER') or '' end

  return titlecase(user), titlecase(host), path
end

wezterm.on('update-right-status', function(window, pane)
  local items = {}
  if P.status_bar_bg then
    table.insert(items, { Background = { Color = P.status_bar_bg } })
    table.insert(items, { Foreground = { Color = P.status_bar_fg } })
  end
  local kt = window:active_key_table()
  if kt then                                  -- in a repeatable mode: accent badge
    local MODE = {
      resize_pane = '⤢ RESIZE ↑↓←→', activate_pane = '✛ MOVE ↑↓←→',
      rotate_pane = '⟳ ROTATE ↑↓←→', switch_tab = '⇥ TAB ←→', font_size = 'A± FONT ↑↓0',
    }
    if P.status_bar_bg then
      table.insert(items, { Background = { Color = '#005a9e' } })
      table.insert(items, { Foreground = { Color = P.status_bar_fg } })
    else
      table.insert(items, { Background = { Color = P.accent } })
      table.insert(items, { Foreground = { Color = P.base } })
    end
    table.insert(items, { Attribute = { Intensity = 'Bold' } })
    table.insert(items, { Text = ' ' .. (MODE[kt] or kt) .. ' · Esc ' })
    if P.status_bar_bg then
      table.insert(items, { Background = { Color = P.status_bar_bg } })
      table.insert(items, { Foreground = { Color = P.status_bar_fg } })
    else
      table.insert(items, { Background = { Color = P.crust } })
      table.insert(items, { Foreground = { Color = P.overlay1 } })
    end
    table.insert(items, { Attribute = { Intensity = 'Normal' } })
    table.insert(items, { Text = '  ' })
  elseif window:leader_is_active() then        -- leader pending: bold peach badge
    if P.status_bar_bg then
      table.insert(items, { Background = { Color = '#ffffff' } })
      table.insert(items, { Foreground = { Color = P.status_bar_bg } })
    else
      table.insert(items, { Background = { Color = P.peach } })
      table.insert(items, { Foreground = { Color = P.base } })
    end
    table.insert(items, { Attribute = { Intensity = 'Bold' } })
    table.insert(items, { Text = ' ⌨ LEADER ' })
    if P.status_bar_bg then
      table.insert(items, { Background = { Color = P.status_bar_bg } })
      table.insert(items, { Foreground = { Color = P.status_bar_fg } })
    else
      table.insert(items, { Background = { Color = P.crust } })
      table.insert(items, { Foreground = { Color = P.overlay1 } })
    end
    table.insert(items, { Attribute = { Intensity = 'Normal' } })
    table.insert(items, { Text = '  ' })
  end
  local ws = window:active_workspace()
  if ws ~= 'default' then                              -- workspace only when non-default
    if not P.status_bar_bg then
      table.insert(items, { Foreground = { Color = P.accent } })
    end
    table.insert(items, { Text = '⬡ ' .. ws })
    if P.status_bar_bg then
      table.insert(items, { Foreground = { Color = P.status_bar_dim } })
    else
      table.insert(items, { Foreground = { Color = P.overlay1 } })
    end
    table.insert(items, { Text = '  │  ' })
  end
  if not P.status_bar_bg then
    table.insert(items, { Foreground = { Color = P.teal } })   -- identity (active pane)
  end
  local pu, ph, ppath = pane_location(pane)
  local identity = (#pu > 0 and #ph > 0) and (pu .. '@' .. ph) or (pu .. ph)
  table.insert(items, { Text = identity })
  if P.status_bar_bg then
    table.insert(items, { Foreground = { Color = P.status_bar_dim } })
  else
    table.insert(items, { Foreground = { Color = P.overlay1 } })
  end
  table.insert(items, { Text = '  │  ' })
  if not P.status_bar_bg then
    table.insert(items, { Foreground = { Color = P.subtext0 } })
  end
  table.insert(items, { Text = ppath .. '  ' })
  window:set_right_status(wezterm.format(items))
  sync_pane_backgrounds(window)
end)

-- ── Dim every pane while the window is unfocused ──────────────────────────────
-- inactive_pane_hsb dims unfocused panes within a focused window; on blur we want
-- a uniform dim across all panes, so we dim all text (foreground_text_hsb) and
-- cancel the per-pane inactive dim. On focus we drop both overrides.
wezterm.on('window-focus-changed', function(window)
  local o = window:get_config_overrides() or {}
  if window:is_focused() then
    o.foreground_text_hsb = nil
    o.inactive_pane_hsb   = nil
    sync_pane_backgrounds(window, true)
  else
    o.foreground_text_hsb = { brightness = 0.35, saturation = 0.8, hue = 1.0 }
    o.inactive_pane_hsb   = { brightness = 1.0, saturation = 1.0, hue = 1.0 }
  end
  window:set_config_overrides(o)
end)

-- Leader, Esc cancels a pending leader (a no-op consumes Esc; with the
-- ~no-timeout leader this is the deliberate way to back out).
table.insert(config.keys, { key = 'Escape', mods = 'LEADER', action = wezterm.action_callback(function() end) })

-- Alt+1..9 → activate tab by number (appended to the literal config.keys above).
for i = 1, 9 do
  table.insert(config.keys, { key = tostring(i), mods = 'ALT', action = act.ActivateTab(i - 1) })
end

