{
  "statusLine": {
    "type": "command",
    "command": "bash {{ .chezmoi.homeDir }}/.claude/statusline-command.sh"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/wez-tab-status.sh thinking"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/wez-tab-status.sh working"
          }
        ]
      }{{ if eq (index . "ccTtsEnabled" | default "false") "true" }},
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/cc-speak-input.sh question"
          }
        ]
      }{{ end }}
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/wez-tab-status.sh waiting"
          }{{ if eq (index . "ccTtsEnabled" | default "false") "true" }},
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/cc-speak.sh waiting"
          }{{ end }}
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/wez-tab-status.sh error"
          }{{ if eq (index . "ccTtsEnabled" | default "false") "true" }},
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/cc-speak.sh error"
          }{{ end }}
        ]
      }
    ]{{ if eq (index . "ccTtsEnabled" | default "false") "true" }},
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/cc-speak-input.sh notification"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/cc-speak-input.sh permission"
          }
        ]
      }
    ]{{ end }}
  }
}
