{
  "model": "opus[1m]",
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "skipAutoPermissionPrompt": true,
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoLogo -NonInteractive -ExecutionPolicy Bypass -File C:/Users/__WIN_USER__/.claude/hooks/wez-tab-status.ps1 -State thinking"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoLogo -NonInteractive -ExecutionPolicy Bypass -File C:/Users/__WIN_USER__/.claude/hooks/wez-tab-status.ps1 -State waiting"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoLogo -NonInteractive -ExecutionPolicy Bypass -File C:/Users/__WIN_USER__/.claude/hooks/wez-tab-status.ps1 -State error"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "agricidaniel-claude-obsidian": {
      "source": {
        "path": "C:/DATA/Workspace_Public/claude-obsidian",
        "source": "directory"
      }
    },
    "gitkraken": {
      "source": {
        "path": "C:/Users/__WIN_USER__/.claude/plugins/marketplaces/gitkraken",
        "source": "directory"
      }
    }
  },
  "enabledPlugins": {
    "claude-obsidian@agricidaniel-claude-obsidian": true,
    "gitkraken-hooks@gitkraken": true
  }
}
