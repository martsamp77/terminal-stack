{{- /* Theme-aware status colours, baked from the saved config (resolvedTheme). */ -}}
{{- $rt := "dark" -}}{{- if hasKey . "resolvedTheme" -}}{{- $rt = .resolvedTheme -}}{{- end -}}
{{- $tp := "C-b" -}}{{- if hasKey . "tmuxPrefixResolved" -}}{{- $tp = .tmuxPrefixResolved -}}{{- end -}}
{{- $bg := "#181825" -}}{{- $fg := "#cdd6f4" -}}{{- $accent := "#89dceb" -}}{{- $dim := "#6c7086" -}}
{{- if eq $rt "light" -}}{{- $bg = "#e6e9ef" -}}{{- $fg = "#4c4f69" -}}{{- $accent = "#04a5e5" -}}{{- $dim = "#9ca0b0" -}}{{- end -}}
# Prefix key: injected from the saved terminal-stack config (default C-b).
# Change it with `ts-config tmux <chord>` (e.g. ctrl-a). Kept separate from the
# WezTerm leader so the two layers don't collide.
set -g prefix {{ $tp }}
unbind C-b
bind {{ $tp }} send-prefix

set -g mouse on
set -g base-index 1
setw -g pane-base-index 1
set -g renumber-windows on
set -g escape-time 10
set -g focus-events on
set -g history-limit 50000

set -g status-interval 5
set -g status-left-length 80
set -g status-style 'bg={{ $bg }},fg={{ $fg }}'
set -g status-left  '#[bold]#S #[fg={{ $accent }}]#H #[default]'
set -g status-right '#[fg={{ $dim }}]#{pane_current_path} | %m/%d/%Y %H:%M'

setw -g automatic-rename on
set -g set-titles on
set -g set-titles-string '#S:#I.#P #W'

# Claude Code passthrough: Shift+Enter and OSC notifications/progress
set -g allow-passthrough on
set -s extended-keys on
set -as terminal-features 'xterm*:extkeys'
set -as terminal-features 'wezterm*:extkeys'
