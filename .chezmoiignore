# Exclude the Windows-side tree from chezmoi's normal apply; it's synced by run_after_90-sync-windows.sh
windows/**

# Repo-level docs and infrastructure (not user-config files)
README.md
ARCHITECTURE.md
CHANGELOG.md
INSTALL.md
CLAUDE.md
LICENSE
.gitignore
.gitattributes
.github/**
bootstrap/**
docs/**
context/**
# Installer entry points + Windows sync script live at the repo root for the
# raw-URL one-liners; they are run from the clone, never deployed to $HOME.
# Without these, chezmoi maps them to ~/install-linux.sh, ~/scripts/…, etc.
install-linux.sh
install-mac.sh
install-wsl.sh
install.ps1
scripts/**

# WezTerm GUI config — applied on macOS only. Native Linux hosts in this stack
# are headless (ssh/PuTTY); Windows gets windows/.wezterm.lua via the sync hook.
{{ if ne .chezmoi.os "darwin" }}
.wezterm.lua
{{ end }}
