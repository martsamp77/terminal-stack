{
  "version": 1,
  "hooks": {
{{- if eq (index . "ccTtsEnabled" | default "false") "true" }}
    "afterFileEdit": [
      {
        "command": "cat > /dev/null",
        "timeout": 1
      }
    ],
    "stop": [
      {
        "command": "{{ .chezmoi.homeDir }}/.cursor/hooks/cursor-tts.sh",
        "timeout": 15
      }
    ],
    "postToolUse": [
      {
        "matcher": "AskQuestion|AskUserQuestion",
        "command": "{{ .chezmoi.homeDir }}/.cursor/hooks/cursor-tts-input.sh",
        "timeout": 15
      }
    ]
{{- end }}
  }
}
