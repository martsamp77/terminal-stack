# alias ohmyzsh="mate ~/.oh-my-zsh"

# ---- starship-stack-start ----
eval "$(starship init zsh)"
# ---- starship-stack-end ----

# ---- terminal-stack-helpers-start ----
autoload -Uz add-zsh-hook
# Hostname-aware title — useful when ssh'ing between boxes; composes with other precmd hooks.
_set_title() { print -Pn "\e]0;%m: %~\a" }
add-zsh-hook precmd _set_title

# Start/attach a Claude Code tmux session for the current repo or named task.
ccs() {
  local name="${1:-$(basename "$PWD")}"
  name="${name//[^A-Za-z0-9_.-]/_}"
  [[ -n "$WEZTERM_PANE" ]] && wezterm cli set-tab-title "cc-$name" >/dev/null 2>&1
  tmux new-session -A -s "cc-$name" -n claude "claude --name \"$name\""
}

# SSH + remote tmux attach/create in one shot.
ssht() {
  local host="$1" sess="${2:-main}"
  if [[ -z "$host" ]]; then echo "usage: ssht host [session]"; return 2; fi
  [[ -n "$WEZTERM_PANE" ]] && wezterm cli set-tab-title "ssh-$host:$sess" >/dev/null 2>&1
  ssh -t -- "$host" "tmux new-session -A -s $(printf '%q' "$sess")"
}

# Workspace navigation (mirrors the ws* PowerShell functions). Each branch is
# guarded on the specific directory's existence, so the same dot_zshrc stays
# correct on WSL, native Linux (no-op), and macOS.
if [[ -d /mnt/c/DATA/Workspace ]]; then
  ws()         { cd /mnt/c/DATA/Workspace }
  wsp()        { cd /mnt/c/DATA/Workspace_Personal }
  wspu()       { cd /mnt/c/DATA/Workspace_Public }
  wscalibra()  { cd /mnt/c/DATA/Workspace/md-validator }
  wsnetsuite() { cd /mnt/c/DATA/Workspace/netsuite-customizations }
elif [[ -d "$HOME/Documents/Workspace" ]]; then
  ws() { cd "$HOME/Documents/Workspace" }
fi
# ---- terminal-stack-helpers-end ----

# ---- cli-tools-start ----
export PATH="$HOME/.local/bin:$PATH"
command -v zoxide >/dev/null && eval "$(zoxide init zsh)"
command -v fzf    >/dev/null && source <(fzf --zsh) 2>/dev/null
command -v eza    >/dev/null && alias ls='eza --icons=always --git --group-directories-first'
command -v bat    >/dev/null && alias cat='bat --paging=never'
# ---- cli-tools-end ----

# Per-machine overrides (not tracked by chezmoi). See dot_zshrc.local.example.
[[ -r "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"
