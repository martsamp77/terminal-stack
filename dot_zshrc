# Hostname-aware title — useful when ssh'ing between boxes; composes with other precmd hooks.
_set_title() { print -Pn "\e]0;%m: %~\a" }
add-zsh-hook precmd _set_title

# Start/attach a Claude Code tmux session for the current repo or named task.
ccs() {
  local name="${1:-$(basename "$PWD")}"
  name="${name//[^A-Za-z0-9_.-]/_}"
  [[ -n "$WEZTERM_PANE" ]] && wezterm cli set-tab-title "cc-$name" >/dev/null 2>&1
  tmux new-session -A -s "cc-$name" -n claude "claude --name \"$name\""
}

# SSH + remote tmux attach/create in one shot.
ssht() {
  local host="$1" sess="${2:-main}"
  if [[ -z "$host" ]]; then echo "usage: ssht host [session]"; return 2; fi
  [[ -n "$WEZTERM_PANE" ]] && wezterm cli set-tab-title "ssh-$host:$sess" >/dev/null 2>&1
  ssh -t -- "$host" "tmux new-session -A -s $(printf '%q' "$sess")"
}

# Shared resolvers for ts-update / ts-rollback.
# TERMINAL_STACK_CHEZMOI overrides the chezmoi binary (testing / odd installs).
_ts_chezmoi() {
  if [[ -n "${TERMINAL_STACK_CHEZMOI:-}" ]]; then echo "$TERMINAL_STACK_CHEZMOI"
  elif [[ -x "$HOME/.local/bin/chezmoi" ]]; then echo "$HOME/.local/bin/chezmoi"
  elif command -v chezmoi >/dev/null 2>&1; then command -v chezmoi
  else return 1
  fi
}
# Clone resolution: $TERMINAL_STACK_DIR → `chezmoi source-path`. $2 is the
# caller name for error prefixes. Each failure mode gets its own message —
# a chezmoi error (e.g. state lock held by another running instance) is not
# a missing clone, so chezmoi's stderr passes through unredirected.
_ts_src() {
  local cz="$1" name="${2:-ts}" src="${TERMINAL_STACK_DIR:-}"
  if [[ -z "$src" ]]; then
    src="$("$cz" source-path)" || {
      echo "$name: 'chezmoi source-path' failed (error above) — can't locate the clone." >&2
      return 1
    }
  fi
  if [[ ! -d "$src/.git" ]]; then
    if [[ -n "${TERMINAL_STACK_DIR:-}" ]]; then
      echo "$name: \$TERMINAL_STACK_DIR='$TERMINAL_STACK_DIR' is not a git clone." >&2
    else
      echo "$name: no terminal-stack clone at '$src'. Re-run the install one-liner." >&2
    fi
    return 1
  fi
  echo "$src"
}
_TS_STATE="${XDG_STATE_HOME:-$HOME/.local/state}/terminal-stack"

# Pull the latest terminal-stack from GitHub and re-apply via chezmoi.
# Shows incoming commits and records the pre-update SHA so ts-rollback can undo.
# Same name as the PowerShell alias for cross-shell muscle memory.
ts-update() {
  local cz src
  cz="$(_ts_chezmoi)" || { echo "ts-update: chezmoi not found on PATH." >&2; return 1 }
  src="$(_ts_src "$cz" ts-update)" || return 1
  # Preflight: a sourceDir pointing at a non-terminal-stack clone means a stale
  # install. Nudge toward ts-doctor rather than pulling the wrong repo.
  git -C "$src" config --get remote.origin.url 2>/dev/null | grep -qi terminal-stack \
    || echo "ts-update: note — '$src' doesn't look like a terminal-stack clone. Run 'ts-doctor' to check." >&2
  git -C "$src" fetch --quiet || return $?
  local incoming
  incoming="$(git -C "$src" log --oneline 'HEAD..@{u}' 2>/dev/null)"
  if [[ -n "$incoming" ]]; then
    echo "==> incoming changes:"
    print -r -- "$incoming" | sed 's/^/  /'
    # Record the rollback point only when something is actually incoming —
    # a no-op re-run must not clobber the last real rollback point.
    mkdir -p "$_TS_STATE"
    git -C "$src" rev-parse HEAD > "$_TS_STATE/rollback-sha"
    echo "==> recorded rollback point: $(git -C "$src" rev-parse --short HEAD) (ts-rollback to undo)"
    git -C "$src" pull --ff-only || return $?
  else
    echo "==> already up to date"
  fi
  # Re-bake the resolved (light/dark) palette from the live OS theme so a
  # `follow`-mode user who toggled the OS appearance gets the new Starship/tmux
  # palette on this update. No-op for fixed dark/light. Runs in bash because the
  # helpers are bash; failure is non-fatal.
  TERMINAL_STACK_DIR="$src" TERMINAL_STACK_CHEZMOI="$cz" \
    bash -c 'source "$1/bootstrap/_config.sh" && ts_refresh_resolved_theme' _ "$src" >/dev/null 2>&1 || true
  # `apply` without -v: -v prints the full content of every run_after_*
  # script (incl. our 114-line sync hook) as a git-style diff on every run,
  # which looks like a pager opening on long-output. Use `chezmoi diff` if
  # you want to preview.
  "$cz" apply
}

# Undo the last ts-update: reset the clone to the recorded pre-update SHA and
# re-apply. Manual fallback (state file missing): README § Updating & rollback.
ts-rollback() {
  local cz src
  cz="$(_ts_chezmoi)" || { echo "ts-rollback: chezmoi not found on PATH." >&2; return 1 }
  src="$(_ts_src "$cz" ts-rollback)" || return 1
  local sha_file="$_TS_STATE/rollback-sha"
  if [[ ! -f "$sha_file" ]]; then
    echo "ts-rollback: no recorded rollback point ($sha_file)." >&2
    echo "  Manual procedure: git -C $src reset --hard <sha> && chezmoi apply" >&2
    return 1
  fi
  local sha; sha="$(<"$sha_file")"
  if ! git -C "$src" rev-parse --verify --quiet "$sha^{commit}" >/dev/null; then
    echo "ts-rollback: recorded SHA $sha not found in $src." >&2; return 1
  fi
  # The clone may double as a dev checkout — never reset --hard over real work.
  if [[ -n "$(git -C "$src" status --porcelain)" ]]; then
    echo "ts-rollback: $src has uncommitted changes; refusing to reset --hard. Commit or stash first." >&2
    return 1
  fi
  echo "==> resetting $src to $sha (recorded before last ts-update)"
  git -C "$src" reset --hard "$sha" || return $?
  "$cz" apply
  echo "==> done. run ts-update to return to latest."
}

# Configure the stack: leader key, theme (dark/light/follow), tmux prefix, apps.
# Bare `ts-config` opens an interactive menu; `ts-config theme follow` etc. set one
# value. Thin wrapper over the shared bootstrap/ts-config.sh in the clone, which
# persists to chezmoi [data] and re-applies. In a combined WSL+Windows setup, run
# this from WSL — it also mirrors the choice to the Windows side.
ts-config() {
  local cz src
  cz="$(_ts_chezmoi)" || { echo "ts-config: chezmoi not found on PATH." >&2; return 1 }
  src="$(_ts_src "$cz" ts-config)" || return 1
  git -C "$src" config --get remote.origin.url 2>/dev/null | grep -qi terminal-stack \
    || echo "ts-config: note — '$src' doesn't look like a terminal-stack clone. Run 'ts-doctor' to check." >&2
  TERMINAL_STACK_DIR="$src" TERMINAL_STACK_CHEZMOI="$cz" bash "$src/bootstrap/ts-config.sh" "$@"
}

# Diagnose / repair the install: stale chezmoi sourceDir, missing `doc`, leftover
# old clones, tools off PATH. Read-only by default; `ts-doctor --repair` fixes
# (repoints sourceDir + re-applies + offers cleanup, confirming each step).
# Resilient to a broken sourceDir — probes known clone paths so the doctor still
# runs when `chezmoi source-path` is the very thing that's wrong.
ts-doctor() {
  local cz src c
  cz="$(_ts_chezmoi)" || { echo "ts-doctor: chezmoi not found on PATH." >&2; return 1 }
  src="${TERMINAL_STACK_DIR:-$("$cz" source-path 2>/dev/null)}"
  if [[ ! -f "$src/bootstrap/ts-doctor.sh" ]]; then
    for c in "$HOME/code/terminal-stack" "$HOME/terminal-stack" \
             "$HOME/Workspace/terminal-stack" "$HOME/Documents/Workspace/terminal-stack" \
             /mnt/c/Users/*/terminal-stack /mnt/c/DATA/Workspace/terminal-stack; do
      [[ -f "$c/bootstrap/ts-doctor.sh" ]] && { src="$c"; break }
    done
  fi
  if [[ ! -f "$src/bootstrap/ts-doctor.sh" ]]; then
    echo "ts-doctor: can't locate a terminal-stack clone. Re-run the install one-liner." >&2
    return 1
  fi
  TERMINAL_STACK_DIR="$src" TERMINAL_STACK_CHEZMOI="$cz" bash "$src/bootstrap/ts-doctor.sh" "$@"
}

# Workspace navigation (mirrors the ws* PowerShell functions).
# $WORKSPACE_DIR (set in ~/.zshrc.local) wins; otherwise the first existing
# autodetect candidate. Resolved at CALL time, not shell startup, because
# ~/.zshrc.local is sourced after this block.
_ts_workspace() {
  [[ -n "${WORKSPACE_DIR:-}" ]] && { echo "$WORKSPACE_DIR"; return 0 }
  local d
  for d in /mnt/c/DATA/Workspace "$HOME/Documents/Workspace" \
           "$HOME/workspace" "$HOME/Workspace"; do
    [[ -d "$d" ]] && { echo "$d"; return 0 }
  done
  return 1
}
# Sibling resolver: handles both Workspace_Personal (Windows/WSL) and
# Workspace-Personal (macOS) naming.
_ts_workspace_sibling() {
  local suffix="$1" root d
  root="$(_ts_workspace)" || return 1
  for d in "${root}_${suffix}" "${root}-${suffix}"; do
    [[ -d "$d" ]] && { echo "$d"; return 0 }
  done
  return 1
}
ws()   { cd "$(_ts_workspace)" 2>/dev/null || echo "ws: no workspace found — export WORKSPACE_DIR in ~/.zshrc.local" >&2 }
wsp()  { cd "$(_ts_workspace_sibling Personal)" 2>/dev/null || echo "wsp: no *_Personal sibling of $(_ts_workspace 2>/dev/null)" >&2 }
wspu() { cd "$(_ts_workspace_sibling Public)" 2>/dev/null || echo "wspu: no *_Public sibling of $(_ts_workspace 2>/dev/null)" >&2 }
