# ---- cli-tools-start ----
export PATH="$HOME/.local/bin:$PATH"
command -v zoxide >/dev/null && eval "$(zoxide init zsh)"
# fzf --zsh exists from fzf 0.48+ (March 2024); older apt fzf prints
# `unknown option: --zsh` on stderr. Redirect inside the process substitution
# so the source just no-ops on older versions.
command -v fzf    >/dev/null && source <(fzf --zsh 2>/dev/null)
command -v eza    >/dev/null && alias ls='eza --icons=always --git --group-directories-first'
command -v bat    >/dev/null && alias cat='bat --paging=never'

# Open the command reference (~/command-reference.md, chezmoi-managed) plus the
# machine-local supplement (~/command-reference.local.md, untracked) if present.
ref() {
  local -a files=("$HOME/command-reference.md")
  [[ -f "$HOME/command-reference.local.md" ]] && files+=("$HOME/command-reference.local.md")
  if command -v bat >/dev/null; then
    bat --paging=always "${files[@]}"
  else
    less "${files[@]}"
  fi
}
# ---- cli-tools-end ----

# ---- claude-code-start ----
ccnotify() {
    local f="$HOME/.claude/.toast-notify"
    case "${1:-}" in
        on)  touch "$f" && echo 'CC toast: ON' ;;
        off) rm -f "$f" && echo 'CC toast: OFF' ;;
        *)   [[ -f "$f" ]] && echo 'CC toast: ON  (ccnotify off to disable)' \
                           || echo 'CC toast: OFF (ccnotify on  to enable)' ;;
    esac
}
# ---- claude-code-end ----

# Per-machine overrides (not tracked by chezmoi). See dot_zshrc.local.example.
[[ -r "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"
