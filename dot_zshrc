command -v bat    >/dev/null && alias ccat='bat --paging=never'   # ccat, not cat — don't shadow real cat

# ref — alias into the `doc` knowledge base (replaced the old command-reference file).
ref() { doc "$@"; }

# Clipboard helpers: copy stdin (or a file via catclip) to the system clipboard.
clipcopy() {
  if command -v wl-copy >/dev/null 2>&1; then
    wl-copy "$@"
  elif command -v xclip >/dev/null 2>&1; then
    xclip -selection clipboard "$@"
  elif command -v clip.exe >/dev/null 2>&1; then
    clip.exe
  elif command -v pbcopy >/dev/null 2>&1; then
    pbcopy
  else
    echo "clipcopy: no clipboard tool found: install wl-clipboard, xclip, or use WSL clip.exe" >&2
    return 1
  fi
}

catclip() {
  if [[ $# -ne 1 ]]; then
    echo "usage: catclip <file>" >&2
    return 2
  fi
  cat -- "$1" | clipcopy
}
