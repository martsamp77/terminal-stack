#!/usr/bin/env bash
set -uo pipefail
REFDIR="${HOME}/.wezterm-ref"

_wzr_list() {
  echo "Topics:"
  for f in "$REFDIR"/*.txt; do
    name="${f##*/}"
    printf '  wzr %s\n' "${name%.txt}"
  done
}

_wzr_show() {
  if command -v bat >/dev/null 2>&1; then
    bat --style=plain --paging=auto "$1"
  else
    cat "$1"
  fi
}

case "${1:-}" in
  ''|-h|--help)
    echo "Usage: wzr <topic>  |  wzr list"
    echo
    _wzr_list
    ;;
  list)
    _wzr_list
    ;;
  *)
    f="$REFDIR/$1.txt"
    if [[ ! -f "$f" ]]; then
      echo "wzr: no topic '$1' — run 'wzr list'" >&2
      exit 1
    fi
    _wzr_show "$f"
    ;;
esac
